# Copy to .env and adjust paths.
#
# Frontend (Next.js): point at this API including the version prefix, e.g.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# All dataset paths are under this repo: cissy-backend/data/

# Persistent DuckDB file (./data/ is created on startup if missing)
DUCKDB_PATH=./data/instacart.duckdb

# Raw CSVs (e.g. Instacart) — drop files here; ./data/csv/ is created on startup
DATA_CSV_DIR=./data/csv

# Optional: OpenAPI / routing when behind a reverse proxy (see FastAPI root_path)
# ROOT_PATH=

# NL → SQL (POST /query). Required for plain-English questions against Instacart in DuckDB.
# OPENAI_API_KEY=sk-...
# BI_NL_MODEL=gpt-4o-mini
# BI_NL_MAX_ROWS=500
