# FastAPI backend (DuckDB) — must include /api/v1 so /conversations and /query resolve correctly
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: default Google Sheet URL for /bi/[jobId] left pane (overridable with ?excel= URL).
# Use ?gid=<tabId> to open a specific tab (e.g. aisles). Avoid #fragments in .env — use gid in the query.
# NEXT_PUBLIC_BI_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/<ID>/edit?gid=...

# Optional: multiple sheets — JSON array of { "name", "url" } (full Google Sheet URLs), overrides src/config/bi-spreadsheet-tabs.ts
# NEXT_PUBLIC_BI_SPREADSHEET_TABS=[{"name":"Aisles","url":"https://docs.google.com/spreadsheets/d/.../edit?gid=..."}]
